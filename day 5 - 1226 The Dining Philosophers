#include <mutex>

class DiningPhilosophers {
private:
    std::mutex tableMtx; // Global mutex to lock the entire table operation

public:
    DiningPhilosophers() {
        
    }

    void wantsToEat(int philosopher,
                    function<void()> pickLeftFork,
                    function<void()> pickRightFork,
                    function<void()> eat,
                    function<void()> putLeftFork,
                    function<void()> putRightFork) {
        
        // Lock the table so only one philosopher can pick up forks and eat at a time
        std::lock_guard<std::mutex> lock(tableMtx);
        
        pickLeftFork();
        pickRightFork();
        eat();
        putLeftFork();
        putRightFork();
    }
};
