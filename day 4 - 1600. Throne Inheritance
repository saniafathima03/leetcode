
    #include <string>
    #include <vector>
    #include <unordered_map>
    #include <unordered_set>

    using namespace std;

    class ThroneInheritance {
    private:
        string king;
        // Map to store the tree structure: parent -> list of children
        unordered_map<string, vector<string>> familyTree;
        // Set to keep track of dead people
        unordered_set<string> deadMembers;

        // Helper function to perform Pre-order DFS traversal
        void dfs(const string& currentPerson, vector<string>& order) {
            // If the current person is alive, add them to the inheritance list
            if (deadMembers.find(currentPerson) == deadMembers.end()) {
                order.push_back(currentPerson);
            }
            
            // Recursively visit all children in the order of their birth
            if (familyTree.find(currentPerson) != familyTree.end()) {
                for (const string& child : familyTree[currentPerson]) {
                    dfs(child, order);
                }
            }
        }

    public:
        ThroneInheritance(string kingName) {
            king = kingName;
        }
        
        void birth(string parentName, string childName) {
            familyTree[parentName].push_back(childName);
        }
        
        void death(string name) {
            deadMembers.insert(name);
        }
        
        vector<string> getInheritanceOrder() {
            vector<string> order;
            dfs(king, order);
            return order;
        }
    };
