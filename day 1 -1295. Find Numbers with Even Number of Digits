class Solution {
public:
    int findNumbers(vector<int>& nums) {
        int evenDigitCount = 0;
        
        for (int num : nums) {
            int digits = 0;
            // Count the number of digits mathematically
            while (num > 0) {
                digits++;
                num /= 10;
            }
            // Check if the number of digits is even
            if (digits % 2 == 0) {
                evenDigitCount++;
            }
        }
        
        return evenDigitCount;
    }
};
