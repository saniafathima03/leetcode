class Solution {
public:
    bool checkStraightLine(vector<vector<int>>& coordinates) {
        int x0 = coordinates[0][0];
        int y0 = coordinates[0][1];
        int x1 = coordinates[1][0];
        int y1 = coordinates[1][1];
        
        // Calculate the initial dx and dy between the first two points
        int dx = x1 - x0;
        int dy = y1 - y0;
        
        // Check if all subsequent points maintain the same slope using cross product
        for (int i = 2; i < coordinates.size(); i++) {
            int curr_dx = coordinates[i][0] - x0;
            int curr_dy = coordinates[i][1] - y0;
            
            if (dy * curr_dx != curr_dy * dx) {
                return false;
            }
        }
        
        return true;
    }
};
