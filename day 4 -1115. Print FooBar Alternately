#include <mutex>
#include <condition_variable>

class FooBar {
private:
    int n;
    std::mutex mtx;
    std::condition_variable cv;
    bool fooTurn = true; // Tracks which thread's turn it is

public:
    FooBar(int n) {
        this->n = n;
    }

    void foo(function<void()> printFoo) {
        for (int i = 0; i < n; i++) {
            std::unique_lock<std::mutex> lock(mtx);
            // Wait until it is foo's turn
            cv.wait(lock, [this]() { return fooTurn; });
            
            // printFoo() outputs "foo". Do not change or remove this line.
            printFoo();
            
            // Switch turn to bar and notify the waiting thread
            fooTurn = false;
            cv.notify_one();
        }
    }

    void bar(function<void()> printBar) {
        for (int i = 0; i < n; i++) {
            std::unique_lock<std::mutex> lock(mtx);
            // Wait until it is bar's turn
            cv.wait(lock, [this]() { return !fooTurn; });
            
            // printBar() outputs "bar". Do not change or remove this line.
            printBar();
            
            // Switch turn back to foo and notify the waiting thread
            fooTurn = true;
            cv.notify_one();
        }
    }
};
